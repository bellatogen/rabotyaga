# Telegram
TELEGRAM_TOKEN=your_bot_token_here
WEBAPP_URL=https://rabotyaga55.ru

# PostgreSQL (primary store; data.json остаётся как disaster-recovery резерв)
# POSTGRES_PASSWORD используется и сервисом postgres, и в сборке DATABASE_URL.
POSTGRES_PASSWORD=changeme
# Можно переопределить полный URL вручную (иначе собирается из POSTGRES_PASSWORD):
# DATABASE_URL=postgresql://rabotyaga:changeme@postgres:5432/rabotyaga
# PGSSL=1 — включить SSL, если PG вынесен на отдельный managed-хост (не для docker-compose)

# JWT — ОБЯЗАТЕЛЬНО задайте случайную строку 32+ символа в проде!
# Генерация: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-secret-here-min-32-chars

# Часовой пояс расписания пушей (время в редакторе «Пуши» трактуется в нём)
PUSH_TZ=Europe/Moscow

# iiko (iikoServer REST API)
IIKO_URL=https://your-iiko-server.example.com
IIKO_LOGIN=your_iiko_login
IIKO_PASSWORD=your_iiko_password

# mozg.rest — аналитическая платформа (необязательно)
# Если задано, раз в 2 часа синкается дашборд: факт/прогноз/план/гости/чек
MOZG_LOGIN=your_mozg_email@example.com
MOZG_PASSWORD=your_mozg_password
